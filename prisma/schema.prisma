generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  name             String?
  email            String?            @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             Role               @default(STUDENT)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  resetToken       String?            @unique
  resetTokenExpiry DateTime?
  activationStatus String?            @default("PENDING")
  firstName        String?
  gateway          String?
  lastName         String?
  memberCategory   String?
  paymentStatus    String?            @default("FREE")
  sid              String?            @unique
  aiHistory        AIHistory[]
  bookings         Booking[]          @relation("StudentBookings")
  mentorProfile    MentorProfile?
  activities       PlatformActivity[]
  reviews          Review[]           @relation("StudentReviews")
}

model PlatformActivity {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?
  category  String?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  entity    String
  entityId  String?
  adminName String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

model MentorProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  title           String
  credentials     String
  bio             String
  specialties     String[]
  hourlyRate      Float
  currency        String    @default("£")
  stripeAccountId String?
  isVerified      Boolean   @default(false)
  isAvailable     Boolean   @default(true)
  availability    Json?
  bookings        Booking[] @relation("MentorBookings")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews         Review[]  @relation("MentorReviews")
}

model Booking {
  id              String        @id @default(cuid())
  studentId       String
  mentorId        String
  scheduledAt     DateTime
  durationMins    Int           @default(60)
  status          BookingStatus @default(PENDING)
  paymentIntent   String?
  createdAt       DateTime      @default(now())
  meetingLink     String?
  stripeSessionId String?       @unique
  mentor          MentorProfile @relation("MentorBookings", fields: [mentorId], references: [id])
  student         User          @relation("StudentBookings", fields: [studentId], references: [id])
}

model AIHistory {
  id             String   @id @default(cuid())
  userId         String
  toolIdentifier String
  accomplishment String
  metadata       Json?
  timestamp      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id        String        @id @default(cuid())
  rating    Int
  comment   String?
  studentId String
  mentorId  String
  createdAt DateTime      @default(now())
  mentor    MentorProfile @relation("MentorReviews", fields: [mentorId], references: [id], onDelete: Cascade)
  student   User          @relation("StudentReviews", fields: [studentId], references: [id], onDelete: Cascade)
}

enum Role {
  STUDENT
  MENTOR
  ADMIN
  UNIVERSITY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
