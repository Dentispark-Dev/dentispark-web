generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  sid           String?   @unique // System Identity ID (e.g., S-10023)
  firstName     String?
  lastName      String?
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image            String?
  password         String?
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  role             Role      @default(STUDENT)
  
  // Platform Status
  activationStatus String?   @default("PENDING") // ACTIVE, INACTIVE, PENDING, SUSPENDED
  memberCategory   String?   // DENTAL_HYGIENE, BDS, DENTAL_NURSING
  gateway          String?   // e.g., BDS
  paymentStatus    String?   @default("FREE")    // PAID, FREE
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relationships
  mentorProfile MentorProfile?
  bookings      Booking[]     @relation("StudentBookings")
  aiHistory     AIHistory[]
  reviews       Review[]      @relation("StudentReviews")
  activities    PlatformActivity[]
}

model PlatformActivity {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action         String   // e.g., "Updated Personal Statement", "Logged in"
  details        String?
  category       String?  // e.g., "AI", "AUTH", "CONTENT"
  timestamp      DateTime @default(now())
}

model AuditLog {
  id             String   @id @default(cuid())
  adminId        String
  action         String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  entity         String   // Admin, Post, Role, Student
  entityId       String?
  adminName      String?
  details        Json?
  ipAddress      String?
  createdAt      DateTime @default(now())
}

model MentorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  credentials     String
  bio             String   @db.Text
  specialties     String[]
  hourlyRate      Float
  currency        String   @default("£")
  stripeAccountId String?
  isVerified      Boolean  @default(false)
  isAvailable     Boolean  @default(true)
  availability    Json?

  bookings   Booking[] @relation("MentorBookings")
  reviews    Review[]  @relation("MentorReviews")
}

model Booking {
  id            String        @id @default(cuid())
  studentId     String
  mentorId      String
  student       User          @relation("StudentBookings", fields: [studentId], references: [id])
  mentor        MentorProfile @relation("MentorBookings", fields: [mentorId], references: [id])
  scheduledAt     DateTime
  durationMins    Int           @default(60)
  status          BookingStatus @default(PENDING)
  paymentIntent   String?       // Stripe Payment reference
  stripeSessionId String?       @unique
  meetingLink     String?
  createdAt       DateTime      @default(now())
}

model AIHistory {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolIdentifier String
  accomplishment String
  metadata       Json?
  timestamp      DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?  @db.Text
  studentId String
  mentorId  String
  createdAt DateTime @default(now())

  student   User          @relation("StudentReviews", fields: [studentId], references: [id], onDelete: Cascade)
  mentor    MentorProfile @relation("MentorReviews", fields: [mentorId], references: [id], onDelete: Cascade)
}

enum Role {
  STUDENT
  MENTOR
  ADMIN
  UNIVERSITY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
