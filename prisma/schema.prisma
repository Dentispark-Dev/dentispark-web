generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image            String?
  password         String?
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  role             Role      @default(STUDENT)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relationships
  mentorProfile MentorProfile?
  bookings      Booking[]     @relation("StudentBookings")
  aiHistory     AIHistory[]
  reviews       Review[]      @relation("StudentReviews")
}

model MentorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  credentials     String
  bio             String   @db.Text
  specialties     String[]
  hourlyRate      Float
  currency        String   @default("£")
  stripeAccountId String?
  isVerified      Boolean  @default(false)
  isAvailable     Boolean  @default(true)
  availability    Json?

  bookings   Booking[] @relation("MentorBookings")
  reviews    Review[]  @relation("MentorReviews")
}

model Booking {
  id            String        @id @default(cuid())
  studentId     String
  mentorId      String
  student       User          @relation("StudentBookings", fields: [studentId], references: [id])
  mentor        MentorProfile @relation("MentorBookings", fields: [mentorId], references: [id])
  scheduledAt     DateTime
  durationMins    Int           @default(60)
  status          BookingStatus @default(PENDING)
  paymentIntent   String?       // Stripe Payment reference
  stripeSessionId String?       @unique
  meetingLink     String?
  createdAt       DateTime      @default(now())
}

model AIHistory {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolIdentifier String
  accomplishment String
  metadata       Json?
  timestamp      DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?  @db.Text
  studentId String
  mentorId  String
  createdAt DateTime @default(now())

  student   User          @relation("StudentReviews", fields: [studentId], references: [id], onDelete: Cascade)
  mentor    MentorProfile @relation("MentorReviews", fields: [mentorId], references: [id], onDelete: Cascade)
}

enum Role {
  STUDENT
  MENTOR
  ADMIN
  UNIVERSITY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
